{
  "name": "currency-database",
  "version": "2.0.0",
  "description": "Zero-dependency currency metadata and amount formatting for JavaScript and TypeScript.",
  "keywords": [
    "currency",
    "currencies",
    "currency-codes",
    "currency-metadata",
    "currency-format",
    "money-format",
    "iso-4217",
    "exchange",
    "local-data",
    "offline",
    "zero-dependency",
    "javascript",
    "typescript",
    "esm",
    "cjs"
  ],
  "homepage": "https://github.com/AntonOshurek/currency-database#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/AntonOshurek/currency-database.git"
  },
  "bugs": {
    "url": "https://github.com/AntonOshurek/currency-database/issues"
  },
  "license": "MIT",
  "author": "Anton Oshurek",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node tests/getters.test.mjs && node tests/format.test.mjs && node tests/regions.test.mjs && node tests/iso4217.test.mjs && node tests/public-api.test.mjs"
  },
  "engines": {
    "node": ">=16"
  },
  "packageManager": "npm@10.0.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
